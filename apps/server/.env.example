# apps/server env (non-Docker local dev). Copy to .env and fill in.
# Validated at startup by packages/env (@t3-oss/env-core) — the process fails
# fast if any of these are missing or malformed.

# Postgres connection string.
DATABASE_URL=postgresql://postgres:password@localhost:5432/salary-management-system

# 32+ char random secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-openssl-rand-base64-32

# Public origin of this server.
BETTER_AUTH_URL=http://localhost:3000

# Origin of the web app, allowed by CORS with credentials.
CORS_ORIGIN=http://localhost:5173

# development | production | test
NODE_ENV=development
