{
  "name": "salary-management-system",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "vitest": "^4.1.7",
      "@types/node": "^22.13.14",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@orpc/client": "^1.13.14",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @salary-management-system/db db:push",
    "db:studio": "turbo -F @salary-management-system/db db:studio",
    "db:generate": "turbo -F @salary-management-system/db db:generate",
    "db:migrate": "turbo -F @salary-management-system/db db:migrate",
    "db:start": "turbo -F @salary-management-system/db db:start",
    "db:watch": "turbo -F @salary-management-system/db db:watch",
    "db:stop": "turbo -F @salary-management-system/db db:stop",
    "db:down": "turbo -F @salary-management-system/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo test",
    "prepare": "husky"
  },
  "dependencies": {
    "@salary-management-system/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@salary-management-system/config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.8.0"
  },
  "packageManager": "bun@1.3.5"
}
