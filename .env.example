# Root env for docker-compose.prod.yml. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- Postgres (the compose stack derives DATABASE_URL from these) ---
POSTGRES_DB=salary_management
POSTGRES_USER=salary
POSTGRES_PASSWORD=change-me-strong-password

# --- Auth ---
# 32+ char random secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-openssl-rand-base64-32
# Public origin of the SERVER (where Better-Auth issues/validates cookies).
BETTER_AUTH_URL=http://localhost:3000

# --- Cross-origin wiring (must be exact origins, no trailing slash) ---
# Origin of the WEB app, allowed by the server's CORS with credentials.
CORS_ORIGIN=http://localhost:8080
# Origin of the SERVER, baked into the web bundle at build time so the
# browser knows where to send /rpc and /api/auth requests.
VITE_SERVER_URL=http://localhost:3000
